# ─────────────────────────────────────────────
#  Solana Sniper Bot — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Your Solana wallet private key (base58 encoded)
# Generate a fresh wallet for the bot — don't use your main wallet
PRIVATE_KEY=your_base58_private_key_here

# Solana RPC endpoint — use a fast private RPC for best results
# Free options: https://api.mainnet-beta.solana.com (slow, rate-limited)
# Paid options: Helius, QuickNode, Alchemy (recommended)
RPC_URL=https://api.mainnet-beta.solana.com

# Jito block engine endpoint (for priority bundle submission)
# Leave as default unless you have a private Jito endpoint
JITO_URL=https://mainnet.block-engine.jito.wtf

# ── Trading parameters ──────────────────────────────────────────────

# Amount of SOL to spend per snipe (e.g. 0.1 = 0.1 SOL)
BUY_AMOUNT_SOL=0.1

# Slippage tolerance in basis points (500 = 5%, 1000 = 10%)
SLIPPAGE_BPS=500

# Jito tip in SOL for priority execution (0.001 = cheap, 0.05 = competitive)
# Increase during hot launches to beat other snipers
JITO_TIP_SOL=0.005

# Max buy tax to allow (some tokens have buy taxes, %)
MAX_BUY_TAX=10

# ── Filters ────────────────────────────────────────────────────────

# Minimum RugCheck score (0–100). Below this = skip
MIN_RUGCHECK_SCORE=80

# Maximum % of supply the top 10 holders can own
MAX_TOP10_HOLDER_PCT=40

# Maximum % of supply the dev wallet can own
MAX_DEV_HOLDER_PCT=10

# Minimum liquidity in USD before sniping
MIN_LIQUIDITY_USD=5000

# Skip tokens where bundles were detected at launch (true/false)
SKIP_BUNDLED=true

# ── Exit parameters ─────────────────────────────────────────────────

# Take profit ladder (comma-separated multipliers at which to sell %)
# "2,3,5" = sell at 2x, 3x, 5x
TAKE_PROFIT_MULTIPLIERS=2,3,5

# % of position to sell at each take profit level (must match above count)
# "30,30,20" = sell 30% at 2x, 30% at 3x, 20% at 5x (20% moonbag)
TAKE_PROFIT_PERCENTS=30,30,20

# Stop loss — sell 100% if price drops this % from entry
STOP_LOSS_PCT=40

# ── Telegram alerts (optional) ─────────────────────────────────────

# Set TELEGRAM_ENABLED=true and fill in bot token + chat ID for alerts
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Mode ───────────────────────────────────────────────────────────

# Paper trading mode — simulates trades without spending real SOL
# Use: npm run paper  OR set PAPER_MODE=true here
PAPER_MODE=false

# How many tokens to snipe concurrently (1–3 recommended)
MAX_CONCURRENT_SNIPES=1
